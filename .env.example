# Copy this file to .env and fill in real values.
# .env itself is gitignored and must NEVER be committed.

# Generate a fresh one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-real-random-secret-key

# --- Production-only settings (not needed for local development) ---
# Comma-separated list of domains this app is allowed to serve, e.g.:
# ALLOWED_HOSTS=myapp.onrender.com,www.myapp.com
ALLOWED_HOSTS=

# Provided automatically by most hosts (Render/Railway/Fly.io) when you
# attach a PostgreSQL database — copy its value here if setting up
# manually, e.g.:
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# Set to False only if your platform already terminates HTTPS AND
# handles the redirect itself (rare) — leave True/unset otherwise.
SECURE_SSL_REDIRECT=True
